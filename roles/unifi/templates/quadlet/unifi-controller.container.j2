[Unit]
Description=UniFi Network Controller
Requires=mongodb.service
After=mongodb.service
StartLimitIntervalSec=60
StartLimitBurst=3

[Container]
Image=lscr.io/linuxserver/unifi-network-application:latest
ContainerName=unifi-controller
Volume=unifi-data.volume:/config
Environment=PUID={{ unifi_user_uid }}
Environment=PGID={{ unifi_user_gid }}
Environment=TZ=Europe/London
Environment=MONGO_USER={{ unifi_mongodb_user }}
Environment=MONGO_PASS={{ unifi_mongodb_password }}
Environment=MONGO_HOST=mongodb
Environment=MONGO_PORT=27017
Environment=MONGO_DBNAME={{ unifi_mongodb_database }}
PublishPort=8080:8080
PublishPort=8843:8843
PublishPort=8880:8880
PublishPort=6789:6789
PublishPort=3478:3478/udp
PublishPort=10001:10001/udp
PublishPort=5514:5514/udp
Network=unifi.network

[Service]
Restart=on-failure

[Install]
WantedBy=multi-user.target default.target
